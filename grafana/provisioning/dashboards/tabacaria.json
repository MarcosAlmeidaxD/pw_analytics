{
  "id": null,
  "uid": "tabacaria-main",
  "title": "Tabacaria — Vendas em Tempo Real",
  "tags": ["tabacaria", "realtime"],
  "timezone": "browser",
  "refresh": "3s",
  "time": { "from": "now-30m", "to": "now" },
  "schemaVersion": 39,
  "version": 1,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Transações (últimos 30min)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
        "editorMode": "code", "rawQuery": true,
        "rawSql": "SELECT COUNT(*) FROM live_feed WHERE $__timeFilter(event_time)",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Receita Aprovada (últimos 30min)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyBRL", "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
        "editorMode": "code", "rawQuery": true,
        "rawSql": "SELECT COALESCE(ROUND(SUM(total_amount)::numeric, 2), 0) FROM live_feed WHERE $__timeFilter(event_time) AND payment_status = 'aprovado'",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Aprovadas vs Recusadas",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Recusadas" },
          "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
        }]
      },
      "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
        "editorMode": "code", "rawQuery": true,
        "rawSql": "SELECT COUNT(*) FILTER (WHERE payment_status = 'aprovado') AS \"Aprovadas\", COUNT(*) FILTER (WHERE payment_status = 'recusado') AS \"Recusadas\" FROM live_feed WHERE $__timeFilter(event_time)",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 4,
      "type": "gauge",
      "title": "Taxa de Aprovação",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "minVizWidth": 75, "minVizHeight": 75,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false, "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1, "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "green",  "value": 85   }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
        "editorMode": "code", "rawQuery": true,
        "rawSql": "SELECT COALESCE(ROUND(100.0 * COUNT(*) FILTER (WHERE payment_status = 'aprovado') / NULLIF(COUNT(*), 0), 1), 0) FROM live_feed WHERE $__timeFilter(event_time)",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 5,
      "type": "table",
      "title": "Transações ao Vivo",
      "description": "Últimas 150 transações — atualiza a cada 3s",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 4 },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Horário" }],
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ID" },
            "properties": [{ "id": "custom.width", "value": 300 }]
          },
          {
            "matcher": { "id": "byName", "options": "Horário" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "Valor (R$)" },
            "properties": [
              { "id": "unit", "value": "currencyBRL" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 120 },
              { "id": "custom.align", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pagamento" },
            "properties": [
              { "id": "custom.width", "value": 150 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "pix":            { "text": "Pix",     "color": "green"  } } },
                  { "type": "value", "options": { "cartao_credito": { "text": "Credito",  "color": "blue"   } } },
                  { "type": "value", "options": { "cartao_debito":  { "text": "Debito",   "color": "purple" } } },
                  { "type": "value", "options": { "boleto":         { "text": "Boleto",   "color": "orange" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "aprovado":  { "text": "Aprovado",  "color": "green"  } } },
                  { "type": "value", "options": { "recusado":  { "text": "Recusado",  "color": "red"    } } },
                  { "type": "value", "options": { "pendente":  { "text": "Pendente",  "color": "yellow" } } },
                  { "type": "value", "options": { "estornado": { "text": "Estornado", "color": "orange" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Produto" },
            "properties": [{ "id": "custom.width", "value": 230 }]
          },
          {
            "matcher": { "id": "byName", "options": "Categoria" },
            "properties": [{ "id": "custom.width", "value": 130 }]
          }
        ]
      },
      "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "tabacaria-postgres" },
        "editorMode": "code", "rawQuery": true,
        "rawSql": "SELECT transaction_id AS \"ID\", payment_method AS \"Pagamento\", event_time AS \"Horário\", total_amount AS \"Valor (R$)\", product_name AS \"Produto\", category AS \"Categoria\", payment_status AS \"Status\" FROM live_feed WHERE $__timeFilter(event_time) ORDER BY event_time DESC LIMIT 150",
        "format": "table", "refId": "A"
      }]
    }

  ]
}
